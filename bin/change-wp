#!/bin/bash

# =============================================================================
# Authors:      Román García Guill
# Contact:      romangarciaguill@gmail.com
# Created:      Wed 13 May 2026
#
# Purpose:      Cycle wallpapers
# =============================================================================

wallpaper_dir="$HOME/Pictures/Wallpapers"
current_link="$wallpaper_dir/current"

mapfile -t wallpapers < <(
    find "$wallpaper_dir" \
        -maxdepth 1 \
        -type f \
        \( \
            -iname "*.png" -o \
            -iname "*.jpg" -o \
            -iname "*.jpeg" -o \
            -iname "*.webp" \
        \) \
        | sort
)

current="$(readlink -f "$current_link")"

next=""

for i in "${!wallpapers[@]}"; do
    if [[ "${wallpapers[$i]}" == "$current" ]]; then
        next="${wallpapers[$(( (i + 1) % ${#wallpapers[@]} ))]}"
        break
    fi
done

if [[ -z "$next" ]]; then
    next="${wallpapers[0]}"
fi

ln -sfn "$next" "$current_link"

swaymsg output "*" bg "$next" fill

notify-send \
    -t 3000 \
    "Wallpaper" \
    "$(basename "$next")"
