#
# Purpose:      Git pulls all the repos and synthes all the necessary. 
# =============================================================================

REPOS=(
    "$HOME/Codes"
    "$HOME/Documents/MasterThesis"
    "$HOME/Exercices"
    "$HOME/Notes"
    "$HOME/Tools"
    # "$HOME/Music"
    # "$HOME/Resources"
)

echo "STARTING git push"
for repo in "${REPOS[@]}"; do
    cd $repo
    git add .
    git commit -m "Automatic commit"
    git push
    echo "-->$repo was pushed"
done
echo "COMPLETED"

git status --short

rsync -avh \
    "$HOME/Notes/" \
    "$BACKUP_DRIVE/Notes/"
tar -czf \
"$HOME/backups/notes_$(date +%F).tar.gz" \
"$HOME/Notes"

Lines of code written today
Commits today
Notes modified
Papers read
