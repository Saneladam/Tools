#!/bin/bash

# =============================================================================
# Authors:      Román García Guill
# Contact:      romangarciaguill@gmail.com
# Created:      Thu 18. Jun 2026
#
# Purpose:      Changes the default of the touchpad option in the sway config. 
# =============================================================================

set -euo pipefail

CONFIG="$HOME/.config/sway/config"

# state=$(
#     swaymsg -t get_inputs -r |
#     jq -r '.[] | select(.type=="touchpad") | .libinput.tap'
# )
state=$(
    swaymsg -t get_inputs -r |
    jq -r '.[] | select(.type=="touchpad") | .libinput.tap' |
    head -n1
)
printf '<%s>\n' "$state"

if [[ "$state" == enabled ]]; then
    swaymsg input type:touchpad tap disabled
    sed -i \
        's/^[[:space:]]*tap enabled/tap disabled/' \
        "$CONFIG"
    notify-send "Touchpad" "Tap disabled"
else
    swaymsg input type:touchpad tap enabled
    sed -i \
        's/^[[:space:]]*tap disabled/tap enabled/' \
        "$CONFIG"
    notify-send "Touchpad" "Tap enabled"
fi
