REPOS=(
    "$HOME/Codes"
    "$HOME/Documents/MasterThesis"
    "$HOME/Exercices"
    "$HOME/Notes"
    "$HOME/Tools"
    # "$HOME/Music"
    # "$HOME/Resources"
)

echo "STARTITG git pull"
for repo in "${REPOS[@]}"; do
    cd $repo
    git pull origin main
    echo "$repo was pulled"
done
echo "COMPLETED git pull"
