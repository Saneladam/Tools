#!/bin/bash

TERMINAL="alacritty"
folder="$HOME/Notes"
TODO_DIR="$HOME/Notes/ToDo.md"

source ~/.config/bemenu/theme.sh

newnote () {
    name="$(
        echo "" | bemenu "${BEMENU_OPTS[@]}" -p 'Enter note name:'
    )"

    : "${name:=$(date +%F-%a | tr ':' '_')}"

    setsid -f "$TERMINAL" -e nvim "$folder/$name.md" >/dev/null 2>&1
}

selected () {

    choice=$(
        {
            echo "NEW"
            echo "ToDo"
            find "$folder" \
                -path "$folder/.git" -prune -o \
                -type f \
                -printf "%T@ %p\n" \
                | sort -nr \
                | cut -d' ' -f2-
        } \
        | bemenu "${BEMENU_OPTS[@]}" -p "Choose note:"
    ) || exit 1

    case "$choice" in
        NEW)
            newnote
            ;;
        ToDo)
            setsid -f "$TERMINAL" -e nvim "$TODO_DIR" >/dev/null 2>&1
            ;;
        *)
            setsid -f "$TERMINAL" -e nvim "$choice" >/dev/null 2>&1
            ;;
    esac
}

selected
