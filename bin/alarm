#!/usr/bin/env python3

# =============================================================================
# Authors:      Román García Guill
# Contact:      romangarciaguill@gmail.com
# Created:      Fri 01. May 2026
#
# Purpose:      Sets a timer and alarm
# =============================================================================

NOTIFICATION=True
BEEP=True

import sys
import time
import termios
import tty
import select
import subprocess
from datetime import datetime, timedelta
import re

# ---------------------------
# color interpolation (blue → red)
# ---------------------------
def color_gradient(progress):
    r = int(255 * progress)
    b = int(255 * (1 - progress))
    return f"\033[38;2;{r};0;{b}m"

RESET = "\033[0m"

# ---------------------------
# notification
# ---------------------------
def notify(title, message):
    try:
        subprocess.run(["notify-send", title, message])
    except Exception:
        pass
def beep():
    try:
        subprocess.run(["beep"])
    except Exception:
        pass
def activate():
    try:
        subprocess.run(["sudo modprobe pcspkr"])
    except Exception:
        pass


# ---------------------------
# non-blocking key read
# ---------------------------
def get_key():
    dr, _, _ = select.select([sys.stdin], [], [], 0)
    if dr:
        return sys.stdin.read(1)
    return None

# ---------------------------
# format time
# ---------------------------
def fmt(t):
    h = int(t // 3600)
    m = int((t % 3600) // 60)
    s = int(t % 60)
    return f"{h:02d}:{m:02d}:{s:02d}"

# ---------------------------
# parse HH:MM
# ---------------------------
def parse_clock_time(s):
    match = re.fullmatch(r"(\d{1,2}):(\d{2})(?::(\d{2}))?", s)
    if not match:
        return None

    h = int(match.group(1))
    m = int(match.group(2))
    s = int(match.group(3) or 0)

    if h > 23 or m > 59 or s > 59:
        return None

    now = datetime.now()
    target = now.replace(hour=h, minute=m, second=s, microsecond=0)

    if target <= now:
        target += timedelta(days=1)

    return int((target - now).total_seconds())

# ---------------------------
# parse relative time
# ---------------------------
def parse_relative(args):
    total_seconds = 0
    pattern = re.compile(r"(\d+(\.\d+)?)([hms]?)")

    for arg in args:
        matches = pattern.findall(arg)

        if not matches:
            return None

        for value, _, unit in matches:
            value = float(value)

            if unit == "h":
                total_seconds += value * 3600
            elif unit == "m" or unit == "":
                total_seconds += value * 60
            elif unit == "s":
                total_seconds += value

    return int(total_seconds)

# ---------------------------
# unified parser
# ---------------------------
def parse_time():
    args = sys.argv[1:]

    if not args:
        print("Usage: alarm <time>")
        sys.exit(1)

    if len(args) == 1 and ":" in args[0]:
        seconds = parse_clock_time(args[0])
        if seconds is not None:
            return seconds
        else:
            print("Invalid clock format (HH:MM or HH:MM:SS)")
            sys.exit(1)

    if len(args) == 1 and re.fullmatch(r"\d+(\.\d+)?", args[0]):
        return int(float(args[0]) * 60)

    seconds = parse_relative(args)
    if seconds is None or seconds <= 0:
        print("Invalid time format")
        sys.exit(1)

    return seconds

# ---------------------------
# main loop
# ---------------------------
def main():
    if BEEP: activate()
    total_time = parse_time()
    if NOTIFICATION: notify("Alarm started", f"Timer for {fmt(total_time)}")

    remaining = total_time
    paused = False

    fd = sys.stdin.fileno()
    old_settings = termios.tcgetattr(fd)
    tty.setcbreak(fd)

    start = time.time()

    try:
        while remaining > 0:
            now = time.time()

            if not paused:
                elapsed = now - start
                remaining = max(0, total_time - int(elapsed))

            progress = 1 - (remaining / total_time)
            color = color_gradient(progress)

            status = "PAUSED" if paused else "RUNNING"

            line = f"{color}{fmt(remaining)} [{status}] (p=pause q=quit){RESET}"
            print("\r" + line + " " * 5, end="", flush=True)

            key = get_key()
            if key == "p":
                paused = not paused
                if not paused:
                    start = time.time() - (total_time - remaining)
            elif key == "q":
                print("\n[INFO] Quit")
                return

            time.sleep(0.1)

        print("\n[INFO] Time completed")
        if NOTIFICATION: notify("Alarm finished", "{fmt(total_time)} completed")
        if BEEP: beep()

    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old_settings)

# ---------------------------
if __name__ == "__main__":
    main()
