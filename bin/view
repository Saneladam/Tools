import argparse
from pathlib import Path
import matplotlib

# Better backend for Arch + Wayland
# matplotlib.use("QtAgg")
# matplotlib.use("TkAgg")

import matplotlib.pyplot as plt
import matplotlib.image as mpimg


def main():
    parser = argparse.ArgumentParser(
        description="Quick image viewer with optional grid and pixel inspection"
    )

    parser.add_argument(
        "image",
        help="Path to image file"
    )

    parser.add_argument(
        "-g", "--grid",
        nargs="?",
        const=50,
        type=int,
        help="Enable grid with optional spacing in pixels (default: 50)"
    )

    args = parser.parse_args()

    img_path = Path(args.image).expanduser()

    if not img_path.exists():
        print(f"Error: file not found -> {img_path}")
        return

    img = mpimg.imread(img_path)

    fig, ax = plt.subplots()
    fig.canvas.manager.set_window_title(img_path.name)

    ax.imshow(img)

    # ----------------------------------------
    # Grid mode
    # ----------------------------------------
    if args.grid is not None:
        step = args.grid

        height, width = img.shape[:2]

        ax.set_xticks(range(0, width, step))
        ax.set_yticks(range(0, height, step))

        ax.grid(True, color="white", alpha=0.35, linewidth=0.8)

        ax.set_xlabel("x [px]")
        ax.set_ylabel("y [px]")

        # Live coordinates in status bar
        ax.format_coord = lambda x, y: f"x={x:.1f}, y={y:.1f}"

    else:
        ax.axis("off")

    # ----------------------------------------
    # Mouse click callback
    # ----------------------------------------
    def onclick(event):
        if event.xdata is not None and event.ydata is not None:
            print(f"Clicked at x={event.xdata:.1f}, y={event.ydata:.1f}")

    fig.canvas.mpl_connect("button_press_event", onclick)

    plt.tight_layout()
    plt.show()


if __name__ == "__main__":
    main()
