#!/bin/bash

# =============================================================================
# Authors:      Roman Garcia Guill
# Contact:      romangarciaguill@gmail.com
# Created:      Thu 04. Dec 2025
#
# Purpose:      Run a list of all the available manuals and prints the selected
#               with zathura.
# =============================================================================

source "$HOME/.config/bemenu/theme.sh"

choice=$(
    man -k . \
        | sort \
        | bemenu "${BEMENU_OPTS[@]}" -p "Manual:"
) || exit 1

[ -z "$choice" ] && exit 0

# Extraer nombre
name=$(sed -E 's/^([^(]+)\(.*/\1/' <<< "$choice")

# Extraer sección
section=$(sed -E 's/^[^(]+\(([^)]+)\).*/\1/' <<< "$choice")

# Algunas páginas aparecen como:
# (3const, 3head, 3type)
# Nos quedamos con la primera.
section=${section%%,*}
section=$(echo "$section" | tr -d ' ')

man -Tpdf "$section" "$name" | zathura -
