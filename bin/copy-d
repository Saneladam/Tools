#!/bin/bash

set -e

[ -z "$1" ] && { echo "Uso: copy <archivo>"; exit 1; }

file="$1"
extension=${file%%*.}

case "$extension" in
  pdf)
    if [ -n "$2" ]; then
        pdftotext -f "$2" -l "${3:-$2}" "$file" - | xclip -selection clipboard
    else
        pdftotext "$file" - | xclip -selection clipboard
    fi
    ;;
  *)
    xclip -selection clipboard < "$file"
    ;;
esac

echo "$file" content copied to cplipboard
