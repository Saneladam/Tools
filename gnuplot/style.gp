# style.gp

set terminal pngcairo enhanced font "DejaVu Serif,10" size 900,600
set grid
set border linewidth 1.5

set style line 1 lc rgb "#2c7bb6" lw 2 pt 7 ps 0.8
set style line 2 lc rgb "#d7191c" lw 2 pt 7 ps 0.8
set style line 3 lc rgb "#fdae61" lw 2 pt 7 ps 0.8
set style line 4 lc rgb "#abd9e9" lw 2 pt 7 ps 0.8
