# Directory
function showstorage() {
	du -sh
	echo "--------------------------"
	du -sh * | sort -h | tail -20
}
function mkcd() {
  mkdir -p "$1" && cd "$1"
}
function mkcp() {
    local name="$1"
    mkdir -p "$name"
    for f in *"$name"*; do
       [[ "$f" == "$name" ]] && continue
       cp -r "$f" "$name"
    done
}
function mkmv() {
    local name="$1"
    mkdir -p "$name"
    for f in *"$name"*; do
       [[ "$f" == "$name" ]] && continue
       mv -r "$f" "$name"
    done
}

