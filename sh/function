function git_acp() {
    echo ""
    echo "Git add-commit-push in $(pwd)"
    echo "---------------------------------------------------"
    ls
    echo "---------------------------------------------------"
    git add .
    if [ -z $1 ]; then
        git commit -m "$(date)"
    else;
        git commit -m "$(echo $1)"
    fi
    git push
    echo "---------------------------------------------------"
    echo "All done sir :)"
    echo ""
}
